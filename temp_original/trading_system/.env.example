# =====================================================================
# RAYR MONEY — environment variables
# Copy this file to `.env` and fill in. NEVER commit the real .env.
# =====================================================================

# ─── BROKER SELECTION ────────────────────────────────────────────────
# 'paper'   = in-memory simulator (default, zero risk, no keys needed)
# 'alpaca'  = real Alpaca paper or live trading (US equities)
# 'zerodha' = real Zerodha trading (Indian equities — requires Kite Connect)
BROKER=paper
PAPER_CASH=1000

# ─── ALPACA (US equities) ────────────────────────────────────────────
# 1. Sign up: https://app.alpaca.markets/signup  (paper account is FREE)
# 2. Generate keys: https://app.alpaca.markets/paper/dashboard/overview
#    → look for "API Keys" panel on the right side → "Generate New Key"
# 3. Paste BOTH below. The key must START WITH "PK" for paper.
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# ─── ZERODHA (Indian equities) ───────────────────────────────────────
# Requires Kite Connect subscription (₹2000/mo). Daily OAuth needed.
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=

# ─── TELEGRAM ALERTS (recommended) ───────────────────────────────────
# 1. Create a bot via @BotFather → grab token
# 2. Send your bot a message, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates → find chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── ANALYTICS LOGS ──────────────────────────────────────────────────
TRADE_LOG=logs/trades.jsonl
FEATURE_LOG=logs/features.jsonl
METRICS_PATH=logs/metrics.json
